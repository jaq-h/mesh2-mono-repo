# =============================================================================
# Mesh Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# -----------------------------------------------------------------------------
# Spotify OAuth Configuration
# -----------------------------------------------------------------------------
# Get these from https://developer.spotify.com/dashboard
CLIENT_ID=your_spotify_client_id
CLIENT_SECRET=your_spotify_client_secret

# Redirect URI - must match EXACTLY what's registered in Spotify Dashboard
# Development:
REDIRECT_URI=http://127.0.0.1:3000/redirect
# Production:
# REDIRECT_URI=https://mesh-app.now.sh/redirect

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgres://username:password@localhost:5432/mesh_api_development

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
# Secret key for signing JWTs - use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Development:
HOST=127.0.0.1
PORT=3001
# Production (typically):
# HOST=0.0.0.0
# PORT=8080

# -----------------------------------------------------------------------------
# Frontend URL (for CORS)
# -----------------------------------------------------------------------------
# Development:
FRONTEND_URL=http://127.0.0.1:3000
# Production:
# FRONTEND_URL=https://mesh-app.now.sh

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
RUST_LOG=info
