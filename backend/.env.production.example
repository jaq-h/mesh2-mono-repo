# =============================================================================
# Mesh Backend - Production Environment Variables
# =============================================================================
# Copy this file to .env for production deployment

# -----------------------------------------------------------------------------
# Spotify OAuth Configuration
# -----------------------------------------------------------------------------
# Get these from https://developer.spotify.com/dashboard
CLIENT_ID=your_spotify_client_id
CLIENT_SECRET=your_spotify_client_secret

# Production redirect URI - must be registered in Spotify Dashboard
REDIRECT_URI=https://mesh-app.now.sh/redirect

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Use your production PostgreSQL connection string
# For Vercel Postgres, Supabase, Railway, etc.
DATABASE_URL=postgres://user:password@host:5432/mesh_production?sslmode=require

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
# Use a long, random secret key - generate with: openssl rand -base64 64
JWT_SECRET=your_production_jwt_secret_generate_a_long_random_string
JWT_ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Listen on all interfaces for containerized deployments
HOST=0.0.0.0
# Port is often set by the platform (Vercel, Railway, etc.)
PORT=8080

# -----------------------------------------------------------------------------
# Frontend URL (for CORS)
# -----------------------------------------------------------------------------
FRONTEND_URL=https://mesh-app.now.sh

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Use 'warn' or 'error' in production to reduce noise
RUST_LOG=warn
