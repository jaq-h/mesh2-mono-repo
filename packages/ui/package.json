{
  "name": "@mesh/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared React UI components for Mesh Spotify remote",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./styles": {
      "import": "./src/styles/index.css"
    },
    "./styles/index.css": {
      "import": "./src/styles/index.css"
    },
    "./styles/app.css": {
      "import": "./src/styles/app.css"
    },
    "./src/styles/index.css": "./src/styles/index.css",
    "./src/styles/app.css": "./src/styles/app.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@mesh/spotify-api": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
